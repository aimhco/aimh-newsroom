{
  "name": "aimh-newsroom",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Autonomous AIMH AI newsroom pipeline for verified, video-native daily AI news packages.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "newsroom:collect": "tsx src/cli/index.ts collect",
    "newsroom:rank": "tsx src/cli/index.ts rank",
    "newsroom:plan": "tsx src/cli/index.ts plan",
    "newsroom:capture": "tsx src/cli/index.ts capture",
    "newsroom:voice": "tsx src/cli/index.ts voice",
    "newsroom:render": "tsx src/cli/index.ts render",
    "newsroom:qa": "tsx src/cli/index.ts qa",
    "newsroom:upload": "tsx src/cli/index.ts upload",
    "newsroom:overnight": "tsx src/cli/index.ts overnight",
    "newsroom:resume": "tsx src/cli/index.ts resume",
    "newsroom:dry-run": "tsx src/cli/index.ts overnight --dry-run --fixtures --date 2026-07-09 --no-upload",
    "newsroom:article:validate": "tsx src/cli/articlePreflight.ts",
    "gpt-live:prepare": "tsx src/production/gptLive/cli.ts prepare",
    "gpt-live:seal-exports": "tsx src/production/gptLive/cli.ts seal-exports",
    "gpt-live:motion-smoke": "tsx src/production/gptLive/motion/renderSmoke.ts",
    "gpt-live:finish": "tsx src/production/gptLive/cli.ts finish",
    "gpt-live:qa": "tsx src/production/gptLive/cli.ts qa",
    "gpt56:voice": "tsx src/production/gpt56Episode.ts voice",
    "gpt56:render": "tsx src/production/gpt56Episode.ts render",
    "gpt56:qa": "tsx src/production/gpt56Episode.ts qa",
    "gpt56:all": "tsx src/production/gpt56Episode.ts all",
    "gpt56:revision:voice": "tsx src/production/gpt56Revision.ts voice",
    "gpt56:revision:render": "tsx src/production/gpt56Revision.ts render",
    "gpt56:revision:qa": "tsx src/production/gpt56Revision.ts qa",
    "gpt56:revision:all": "tsx src/production/gpt56Revision.ts all"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "5.2.7",
    "@fontsource/inter": "5.2.8",
    "@remotion/bundler": "4.0.487",
    "@remotion/renderer": "4.0.487",
    "@resvg/resvg-js": "^2.6.2",
    "@resvg/resvg-js-darwin-x64": "2.6.2",
    "playwright": "1.61.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "remotion": "4.0.487"
  },
  "devDependencies": {
    "@rollup/rollup-darwin-x64": "4.62.2",
    "@types/node": "^24.0.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.11"
  },
  "packageManager": "pnpm@11.7.0"
}
